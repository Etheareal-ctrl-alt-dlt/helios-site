---
export interface Props {
  title: string;
  description: string;
  /* Tailwind-style accent name OR a hex/css color directly. */
  accent?: 'pink' | 'mint' | 'purple' | 'blue';
  /* SVG path data — pass just the <path d="..."/> markup as a string,
     or use the slot for full SVG markup. */
  icon: 'heart' | 'leaf' | 'wifi' | 'shield';
}

const { title, description, accent = 'pink', icon } = Astro.props;

const icons: Record<string, string> = {
  heart:  'M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z',
  leaf:   'M11 20A7 7 0 0 1 4 13c0-6 8-13 14-13 0 6-1 14-7 20zM4 13c4 4 6 5 11 5',
  wifi:   'M5 12.55a11 11 0 0 1 14.08 0 M1.42 9a16 16 0 0 1 21.16 0 M8.53 16.11a6 6 0 0 1 6.95 0 M12 20h.01',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
};
---

<div class="feature-item" data-accent={accent}>
  <div class="feature-item__icon" aria-hidden="true">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d={icons[icon]} />
    </svg>
  </div>
  <div class="feature-item__body">
    <h3 class="feature-item__title">{title}</h3>
    <p class="feature-item__desc">{description}</p>
  </div>
</div>

<style>
  .feature-item {
    --accent: var(--pink);
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-4);
  }

  .feature-item[data-accent="pink"]   { --accent: var(--pink);   }
  .feature-item[data-accent="mint"]   { --accent: var(--mint);   }
  .feature-item[data-accent="purple"] { --accent: var(--purple); }
  .feature-item[data-accent="blue"]   { --accent: var(--blue);   }

  .feature-item__icon {
    flex-shrink: 0;
    color: var(--accent);
    padding-top: 2px;
  }

  .feature-item__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .feature-item__title {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .feature-item__desc {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }
</style>
