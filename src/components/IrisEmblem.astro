---
/**
 * IRIS Emblem
 *
 * Per Product Bible v4: "a circular iridescent ring with overlapping
 * translucent arcs cycling through peach, pink, lavender, blue, mint,
 * and gold."
 *
 * Pure SVG + CSS — no images required. The emblem slowly rotates and
 * the conic gradient pulses gently to suggest motion.
 *
 * When Daniel provides the authoritative emblem asset, swap this
 * component for an <img>.
 */

export interface Props {
  size?: number;
  animated?: boolean;
}

const { size = 220, animated = true } = Astro.props;
---

<div class="iris-emblem" style={`--size: ${size}px;`} data-animated={animated}>
  <svg viewBox="0 0 200 200" width={size} height={size} aria-label="IRIS">
    <defs>
      <!-- The iridescent ring color cycle -->
      <linearGradient id="iris-peach"    x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#FFB68A"/>
        <stop offset="100%" stop-color="#FF7FB2"/>
      </linearGradient>
      <linearGradient id="iris-pink"     x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#FF6FA8"/>
        <stop offset="100%" stop-color="#C77AE0"/>
      </linearGradient>
      <linearGradient id="iris-lavender" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#B07FFF"/>
        <stop offset="100%" stop-color="#7CA8FF"/>
      </linearGradient>
      <linearGradient id="iris-blue"     x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#7BC5FF"/>
        <stop offset="100%" stop-color="#8FE4C8"/>
      </linearGradient>
      <linearGradient id="iris-gold"     x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#FFD080"/>
        <stop offset="100%" stop-color="#FFAE7F"/>
      </linearGradient>

      <radialGradient id="iris-inner-glow" cx="0.5" cy="0.5" r="0.5">
        <stop offset="0%" stop-color="rgba(255, 255, 255, 0.18)"/>
        <stop offset="100%" stop-color="rgba(255, 255, 255, 0)"/>
      </radialGradient>
    </defs>

    <!-- Five overlapping arcs, each rotated and tinted. The thick
         stroke + low opacity creates the layered ring sheen. -->
    <g class="iris-arcs" transform="translate(100 100)">
      <circle r="78" fill="none" stroke="url(#iris-peach)"    stroke-width="14" stroke-dasharray="280 200" opacity="0.85" transform="rotate(0)"/>
      <circle r="78" fill="none" stroke="url(#iris-pink)"     stroke-width="14" stroke-dasharray="240 240" opacity="0.75" transform="rotate(72)"/>
      <circle r="78" fill="none" stroke="url(#iris-lavender)" stroke-width="14" stroke-dasharray="260 220" opacity="0.80" transform="rotate(144)"/>
      <circle r="78" fill="none" stroke="url(#iris-blue)"     stroke-width="14" stroke-dasharray="250 230" opacity="0.78" transform="rotate(216)"/>
      <circle r="78" fill="none" stroke="url(#iris-gold)"     stroke-width="14" stroke-dasharray="270 210" opacity="0.70" transform="rotate(288)"/>
    </g>

    <!-- Inner hole + glow -->
    <circle cx="100" cy="100" r="48" fill="url(#iris-inner-glow)"/>
    <circle cx="100" cy="100" r="46" fill="none" stroke="rgba(255,255,255,0.10)" stroke-width="1"/>
  </svg>
</div>

<style>
  .iris-emblem {
    width: var(--size);
    height: var(--size);
    display: grid;
    place-items: center;
    filter:
      drop-shadow(0 0 24px rgba(157, 123, 255, 0.35))
      drop-shadow(0 0 48px rgba(255, 111, 168, 0.22));
  }

  .iris-emblem svg {
    overflow: visible;
  }

  .iris-emblem[data-animated="true"] .iris-arcs {
    transform-origin: 100px 100px;
    animation: iris-rotate 24s linear infinite;
  }

  @keyframes iris-rotate {
    from { transform: translate(100px, 100px) rotate(0deg); }
    to   { transform: translate(100px, 100px) rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .iris-emblem[data-animated="true"] .iris-arcs {
      animation: none;
    }
  }
</style>
