---
import { path } from '../utils/url';

export interface Props {
  line?: 'consumer' | 'professional';
}

const { line = 'consumer' } = Astro.props;

const year = line === 'consumer' ? 2001 : 1993;

const links = line === 'consumer'
  ? ['Privacy', 'Terms', 'Warranty', 'Contact', 'Sitemap']
  : ['Privacy', 'Terms', 'Warranty', 'Contact'];

const logoSrc = line === 'consumer'
  ? path('/images/logos/helios-2001.png')
  : path('/images/logos/helios-1993.png');
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <a href={path('/')} class="site-footer__logo" aria-label="Helios Computer Corporation home">
      <img src={logoSrc} alt="Helios Computer Corporation" class="site-footer__logo-img" />
    </a>

    <nav class="site-footer__menu" aria-label="Secondary">
      <ul>
        {links.map((label) => (
          <li>
            <a href={path(`/${label.toLowerCase()}`)}>{label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <p class="site-footer__copy">
      &copy; {year} Helios Computer Corporation<br/>
      All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-16);
    padding-block: var(--space-10);
    border-top: 1px solid var(--border-soft);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-8);
    align-items: center;
  }

  .site-footer__logo-img {
    height: 72px;
    width: auto;
  }

  .site-footer__menu ul {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .site-footer__menu a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-secondary);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .site-footer__menu a:hover { color: var(--pink); }

  .site-footer__copy {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-align: right;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-5);
      justify-items: center;
    }
    .site-footer__menu ul { justify-content: center; }
    .site-footer__copy { text-align: center; }
  }
</style>
