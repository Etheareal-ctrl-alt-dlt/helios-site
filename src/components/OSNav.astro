---
// OS-family sub-navigation: AURORA · SOLSTICE · HERMES · IRIS
// Sits directly beneath the main Nav on OS/AI detail pages.
// Active item is colored to its line identity (amber pro / pink consumer).
import { path } from '../utils/url';

interface Props {
  current?: 'aurora' | 'solstice' | 'hermes' | 'iris';
}
const { current } = Astro.props;

const items = [
  { key: 'aurora',   label: 'AURORA OS',   href: '#' },
  { key: 'solstice', label: 'SOLSTICE OS', href: '#' },
  { key: 'hermes',   label: 'HERMES',      href: path('/hermes') },
  { key: 'iris',     label: 'IRIS',        href: path('/iris') },
];
---

<nav class="osnav" aria-label="Operating systems and AI companions">
  <div class="osnav__inner">
    {items.map((it) => (
      <a
        href={it.href}
        class:list={['osnav__link', `osnav__link--${it.key}`, { 'is-active': current === it.key }]}
        aria-current={current === it.key ? 'page' : undefined}
      >{it.label}</a>
    ))}
  </div>
</nav>

<style>
  .osnav {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .osnav__inner {
    display: flex;
    justify-content: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    max-width: 1200px;
    margin-inline: auto;
    padding: 0.85rem 1.5rem;
  }
  .osnav__link {
    position: relative;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-tertiary, rgba(255, 255, 255, 0.5));
    text-decoration: none;
    padding-bottom: 0.35rem;
    transition: color var(--duration-fast, 150ms) var(--ease-out, ease);
    white-space: nowrap;
  }
  .osnav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--duration-fast, 150ms) var(--ease-out, ease);
  }
  /* Hover brightens toward the item's line identity */
  .osnav__link--aurora:hover,
  .osnav__link--hermes:hover { color: var(--helios-amber); }
  .osnav__link--solstice:hover,
  .osnav__link--iris:hover { color: var(--pink, #ff86c8); }

  .osnav__link.is-active::after { transform: scaleX(1); }
  .osnav__link--aurora.is-active,
  .osnav__link--hermes.is-active { color: var(--helios-amber); }
  .osnav__link--solstice.is-active,
  .osnav__link--iris.is-active { color: var(--pink, #ff86c8); }

  @media (max-width: 560px) {
    .osnav__inner {
      gap: 1.1rem;
      overflow-x: auto;
      justify-content: flex-start;
      -webkit-overflow-scrolling: touch;
    }
    .osnav__link { font-size: 0.72rem; letter-spacing: 0.12em; }
  }
</style>
