---
export interface Props {
  name: string;
  subtitle: string;
  description: string;
  specs: string[];
  cta: { label: string; href: string };
  /* The accent color this card uses for name + button + spec bullets. */
  accent?: 'pink' | 'purple' | 'blue';
  /* Path to the product hero image, or null to show the SVG placeholder. */
  image?: string | null;
  imageAlt?: string;
}

const {
  name,
  subtitle,
  description,
  specs,
  cta,
  accent = 'pink',
  image = null,
  imageAlt = '',
} = Astro.props;
---

<article class="product-card" data-accent={accent}>
  <header class="product-card__header">
    <h2 class="product-card__name">{name}</h2>
    <p class="product-card__subtitle">{subtitle}</p>
  </header>

  <div class="product-card__media">
    {image ? (
      <img src={image} alt={imageAlt} loading="lazy" />
    ) : (
      <div class="product-card__placeholder" aria-hidden="true">
        <span>{name}</span>
        <small>product render goes here</small>
      </div>
    )}
  </div>

  <p class="product-card__desc">{description}</p>

  <ul class="product-card__specs">
    {specs.map((spec) => (
      <li>
        <svg class="spec-star" width="11" height="11" viewBox="0 0 12 12" aria-hidden="true">
          <path d="M6 0 L7.1 4.9 L12 6 L7.1 7.1 L6 12 L4.9 7.1 L0 6 L4.9 4.9 Z" fill="currentColor"/>
        </svg>
        <span>{spec}</span>
      </li>
    ))}
  </ul>

  <a href={cta.href} class="product-card__cta">
    <span>{cta.label}</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </a>
</article>

<style>
  .product-card {
    --accent: var(--pink);
    --accent-soft: rgba(255, 111, 168, 0.18);

    display: flex;
    flex-direction: column;
    gap: var(--space-4);

    padding: var(--space-6);
    background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-card-2) 100%);
    border-radius: 18px;
    box-shadow: var(--glow-card);
    transition:
      transform var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out);
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--glow-card-hover);
  }

  /* Per-card accent variations */
  .product-card[data-accent="pink"]   { --accent: var(--pink);   --accent-soft: rgba(255, 111, 168, 0.18); }
  .product-card[data-accent="purple"] { --accent: var(--purple); --accent-soft: rgba(157, 123, 255, 0.18); }
  .product-card[data-accent="blue"]   { --accent: var(--blue);   --accent-soft: rgba(123, 197, 255, 0.18); }

  /* ── Header ─────────────────────────────────────────────── */
  .product-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .product-card__name {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: 2.4rem;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--accent);
  }

  .product-card__subtitle {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  /* ── Media ──────────────────────────────────────────────── */
  .product-card__media {
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    margin-block: var(--space-2);
    padding: var(--space-4);
    border-radius: 12px;
    background:
      radial-gradient(ellipse 70% 60% at 50% 50%, var(--accent-soft), transparent 70%);
  }
  .product-card__media img {
    max-height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.4));
  }

  .product-card__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    aspect-ratio: 4 / 3;
    border: 1.5px dashed var(--border-soft);
    border-radius: 8px;
    color: var(--text-muted);
  }
  .product-card__placeholder span {
    font-family: var(--font-display);
    font-weight: var(--weight-extrabold);
    font-size: 1.4rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    opacity: 0.55;
  }
  .product-card__placeholder small {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  /* ── Description ────────────────────────────────────────── */
  .product-card__desc {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text-secondary);
  }

  /* ── Specs ──────────────────────────────────────────────── */
  .product-card__specs {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-block: var(--space-3) var(--space-2);
  }
  .product-card__specs li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-secondary);
  }
  .spec-star { color: var(--accent); flex-shrink: 0; }

  /* ── CTA ────────────────────────────────────────────────── */
  .product-card__cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);

    padding: var(--space-3) var(--space-5);
    border: 1.5px solid var(--accent);
    border-radius: 10px;
    background: transparent;

    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);

    transition:
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }
  .product-card__cta:hover {
    background: var(--accent);
    color: var(--bg-deep);
  }
  .product-card__cta:active { transform: scale(0.98); }
</style>
