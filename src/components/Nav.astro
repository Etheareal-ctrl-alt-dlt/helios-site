---
export interface Props {
  current?: 'products' | 'consumer' | 'professional' | 'support' | 'company' | 'community';
  line?: 'consumer' | 'professional';
}

const { current, line = 'consumer' } = Astro.props;

const items = line === 'consumer'
  ? [
      { id: 'products',     label: 'Products',     href: '/products' },
      { id: 'consumer',     label: 'Consumer',     href: '/consumer' },
      { id: 'support',      label: 'Support',      href: '/support' },
      { id: 'company',      label: 'Company',      href: '/company' },
      { id: 'community',    label: 'Community',    href: '/community' },
    ]
  : [
      { id: 'products',     label: 'Products',     href: '/products' },
      { id: 'professional', label: 'Professional', href: '/professional' },
      { id: 'consumer',     label: 'Consumer',     href: '/consumer' },
      { id: 'support',      label: 'Support',      href: '/support' },
      { id: 'company',      label: 'Company',      href: '/company' },
    ];
---

<header class="site-nav">
  <div class="container site-nav__inner">
    <a href="/" class="site-nav__logo" aria-label="Helios Computer Corporation home">
      <!-- The 2001 starburst wordmark. Drop in your real logo at
           /public/images/logos/helios-2001.png and swap this block
           for an <img>. For now it's a styled text mark. -->
      <span class="logo-mark">
        <span class="logo-mark__word">HELIOS</span>
        <span class="logo-mark__sub">COMPUTER CORPORATION</span>
      </span>
    </a>

    <nav class="site-nav__menu" aria-label="Primary">
      <ul>
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['site-nav__link', { 'is-current': current === item.id }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/cart" class="site-nav__cart" aria-label="Cart">
      <span>Cart (0)</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 6h18l-2 13H5L3 6z"/>
        <path d="M8 6V4a4 4 0 0 1 8 0v2"/>
      </svg>
    </a>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    background: rgba(10, 10, 24, 0.72);
    border-bottom: 1px solid var(--border-soft);
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-4);
  }

  /* ── Logo (styled text placeholder) ─────────────────────── */
  .site-nav__logo {
    flex-shrink: 0;
  }

  .logo-mark {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
    transition: opacity var(--duration-fast) var(--ease-out);
  }
  .logo-mark:hover { opacity: 0.85; }

  .logo-mark__word {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: 1.6rem;
    letter-spacing: 0.02em;
    background: linear-gradient(180deg, #FFD4A8 0%, #FF8B5C 60%, #C44A1F 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow: 0 1px 0 rgba(255, 200, 150, 0.12);
  }

  .logo-mark__sub {
    font-family: var(--font-mono);
    font-size: 0.46rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.32em;
    color: var(--text-secondary);
    margin-top: 2px;
  }

  /* ── Nav menu ───────────────────────────────────────────── */
  .site-nav__menu ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .site-nav__link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
    padding-block: var(--space-2);
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-nav__link:hover {
    color: var(--text-primary);
  }

  .site-nav__link.is-current {
    color: var(--pink);
  }
  .site-nav__link.is-current::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1.5px;
    background: var(--pink);
    border-radius: 1px;
  }

  /* ── Cart ───────────────────────────────────────────────── */
  .site-nav__cart {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .site-nav__cart:hover { color: var(--text-primary); }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .site-nav__menu { display: none; }
    .site-nav__inner { padding-block: var(--space-3); }
    .logo-mark__word { font-size: 1.3rem; }
  }
</style>
