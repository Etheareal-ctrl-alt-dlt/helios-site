---
import { path } from '../utils/url';

export interface Props {
  current?: 'products' | 'consumer' | 'professional' | 'support' | 'company' | 'community';
  line?: 'consumer' | 'professional';
}

const { current, line = 'consumer' } = Astro.props;

const items = line === 'consumer'
  ? [
      { id: 'products',     label: 'Products',     href: path('/products') },
      { id: 'consumer',     label: 'Consumer',     href: path('/consumer') },
      { id: 'support',      label: 'Support',      href: path('/support') },
      { id: 'company',      label: 'Company',      href: path('/company') },
      { id: 'community',    label: 'Community',    href: path('/community') },
    ]
  : [
      { id: 'products',     label: 'Products',     href: path('/products') },
      { id: 'professional', label: 'Professional', href: path('/professional') },
      { id: 'consumer',     label: 'Consumer',     href: path('/consumer') },
      { id: 'support',      label: 'Support',      href: path('/support') },
      { id: 'company',      label: 'Company',      href: path('/company') },
    ];

const logoSrc = line === 'consumer'
  ? path('/images/logos/helios-2001.png')
  : path('/images/logos/helios-1993.png');
---

<header class="site-nav">
  <div class="container site-nav__inner">
    <a href={path('/')} class="site-nav__logo" aria-label="Helios Computer Corporation home">
      <!-- The image has a pure black background — mix-blend-mode: screen
           drops that black into the nav blur cleanly, so the bright
           amber and chrome elements appear to float on the page. -->
      <img src={logoSrc} alt="Helios Computer Corporation" class="site-nav__logo-img" />
    </a>

    <nav class="site-nav__menu" aria-label="Primary">
      <ul>
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['site-nav__link', { 'is-current': current === item.id }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href={path('/cart')} class="site-nav__cart" aria-label="Cart">
      <span>Cart (0)</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 6h18l-2 13H5L3 6z"/>
        <path d="M8 6V4a4 4 0 0 1 8 0v2"/>
      </svg>
    </a>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    background: rgba(10, 10, 24, 0.72);
    border-bottom: 1px solid var(--border-soft);
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-3);
  }

  /* ── Logo ───────────────────────────────────────────────── */
  .site-nav__logo {
    flex-shrink: 0;
    display: inline-flex;
    transition: opacity var(--duration-fast) var(--ease-out);
  }
  .site-nav__logo:hover { opacity: 0.85; }

  .site-nav__logo-img {
    height: 76px;
    width: auto;
    /* lighten + contrast crushes near-black PNG compression noise
       to pure black, which the lighten blend then makes invisible
       against the nav. Cleaner than screen, which slightly lifts
       near-blacks and leaves a faint rectangle around the logo. */
    mix-blend-mode: lighten;
    filter: contrast(1.08);
  }

  /* ── Nav menu ───────────────────────────────────────────── */
  .site-nav__menu ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .site-nav__link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
    padding-block: var(--space-2);
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-nav__link:hover {
    color: var(--text-primary);
  }

  .site-nav__link.is-current {
    color: var(--pink);
  }
  .site-nav__link.is-current::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1.5px;
    background: var(--pink);
    border-radius: 1px;
  }

  /* ── Cart ───────────────────────────────────────────────── */
  .site-nav__cart {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .site-nav__cart:hover { color: var(--text-primary); }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .site-nav__menu { display: none; }
    .site-nav__logo-img { height: 60px; }
  }
</style>
