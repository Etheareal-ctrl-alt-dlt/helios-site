---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import OSNav from '../components/OSNav.astro';
import Footer from '../components/Footer.astro';
import { path } from '../utils/url';

// ── HERMES, spelled down (Bible-canonical expansion) ──────────
// Helios Environment Resource Messaging Extraction System
const acronym = [
  { big: 'H', rest: 'ELIOS' },
  { big: 'E', rest: 'NVIRONMENT' },
  { big: 'R', rest: 'ESOURCE' },
  { big: 'M', rest: 'ESSAGING' },
  { big: 'E', rest: 'XTRACTION' },
  { big: 'S', rest: 'YSTEM' },
];

// ── Four capability cards ─────────────────────────────────────
const features = [
  {
    icon: 'terminal',
    title: 'Command Interpretation',
    body: 'Turns intent into precise command guidance. HERMES understands Aurora’s tools and syntax so you can move faster with confidence.',
  },
  {
    icon: 'layers',
    title: 'Workflow Optimization',
    body: 'Suggests efficient paths through complex tasks, remembers patterns, and helps you build repeatable workflows.',
  },
  {
    icon: 'chip',
    title: 'System Awareness',
    body: 'Deeply integrated with Aurora OS. HERMES sees what the system sees and knows the tools at your disposal.',
  },
  {
    icon: 'target',
    title: 'Professional Register',
    body: 'Curt. Precise. Impersonal. HERMES communicates in a professional tone and gets out of the way once the job is done.',
  },
];

// ── "Built for Operators" capability list ─────────────────────
const capabilities = [
  'Explain complex commands',
  'Recommend next steps',
  'Optimize scripts and processes',
  'Diagnose system issues',
  'Provide precise guidance',
  'Never execute without your approval',
];

const quickCmds = [
  'help', 'man <command>', 'explain <command>', 'examples <command>',
  'optimize <task>', 'diagnose <issue>', 'status', 'clear', 'exit',
];

const stats = [
  ['Commands run', '128'],
  ['Time saved', '2h 34m'],
  ['Accuracy', '99.8%'],
];

// ── Philosophy of control ─────────────────────────────────────
const philosophy = [
  { icon: 'answer', text: 'No assumptions. Only answers.' },
  { icon: 'tools',  text: 'No takeover. Only tools.' },
  { icon: 'focus',  text: 'No distraction. Only clarity.' },
  { icon: 'command', text: 'You command. HERMES assists.' },
];

const IRIS_EMBLEM = path('/images/logos/iris-emblem.png');
---

<BaseLayout
  title="HERMES — Helios Computer Corporation"
  description="Meet HERMES, the command assistant built into Aurora OS. Assistance without interference. He explains, optimizes, and guides — then returns control to the Operator."
  line="professional"
>
  <Nav current="os" line="professional" />
  <OSNav current="hermes" />

  <!-- ════════════════════════════════════════════════════════
       HERO — vertical typewriter acronym + pitch + hero image
       ════════════════════════════════════════════════════════ -->
  <section class="hh" aria-labelledby="hh-title">
    <div class="container hh__inner">

      <!-- Vertical HERMES acronym (types out on load) -->
      <div class="hh-ac" aria-label="HERMES — Helios Environment Resource Messaging Extraction System">
        {acronym.map((row, i) => (
          <div class="hh-ac__row">
            <span class="hh-ac__big">{row.big}</span><span
              class="hh-ac__rest"
              style={`--n:${row.rest.length}; --d:${0.3 + i * 0.55}s`}
            >{row.rest}</span>{i === acronym.length - 1 && <span class="hh-ac__caret" aria-hidden="true"></span>}
          </div>
        ))}
      </div>

      <!-- Pitch -->
      <div class="hh__pitch">
        <h1 id="hh-title" class="hh__title">Assistance Without Interference.</h1>
        <p class="hh__desc">
          HERMES is the command assistant built into Aurora OS. He helps Operators
          understand commands, optimize workflows, and move from intent to execution
          faster. He does not take over. He does not soften the system.
        </p>
        <p class="hh__pull">He delivers answers.<br />You stay in control.</p>
        <div class="hh__cta">
          <a href="#" class="abtn abtn--solid">Explore Aurora OS
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href={path('/professional')} class="abtn abtn--ghost">See Atlas + Titan</a>
        </div>
      </div>

      <!-- Hero image (provided asset, black background) -->
      <div class="hh__image" aria-hidden="true">
        <img
          src={path('/images/os/hermes-screen.png')}
          alt="Helios Atlas workstation running Aurora OS with HERMES"
          loading="eager"
          decoding="async"
        />
      </div>

    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       CAPABILITY CARDS
       ════════════════════════════════════════════════════════ -->
  <section class="hh-feat" aria-label="HERMES capabilities">
    <div class="container">
      <div class="hh-feat__grid">
        {features.map((f) => (
          <div class="hh-card">
            <span class="hh-card__icon" aria-hidden="true">
              {f.icon === 'terminal' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><polyline points="7 9 10 12 7 15"/><line x1="13" y1="15" x2="17" y2="15"/></svg>)}
              {f.icon === 'layers' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 12 15 2 8.5 12 2"/><polyline points="2 14 12 20.5 22 14"/></svg>)}
              {f.icon === 'chip' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="6" width="12" height="12" rx="1.5"/><rect x="9.5" y="9.5" width="5" height="5" rx="0.5"/><line x1="9" y1="2" x2="9" y2="5"/><line x1="15" y1="2" x2="15" y2="5"/><line x1="9" y1="19" x2="9" y2="22"/><line x1="15" y1="19" x2="15" y2="22"/><line x1="2" y1="9" x2="5" y2="9"/><line x1="2" y1="15" x2="5" y2="15"/><line x1="19" y1="9" x2="22" y2="9"/><line x1="19" y1="15" x2="22" y2="15"/></svg>)}
              {f.icon === 'target' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="1.5" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22.5"/><line x1="1.5" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22.5" y2="12"/></svg>)}
            </span>
            <h3 class="hh-card__title">{f.title}</h3>
            <p class="hh-card__body">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       BUILT FOR OPERATORS — capability list + live session
       ════════════════════════════════════════════════════════ -->
  <section class="hh-ops" aria-label="Built for operators">
    <div class="container hh-ops__inner">

      <div class="hh-ops__lead">
        <h2 class="hh-ops__title">Built For Operators.<br />Ready For Any Mission.</h2>
        <p class="hh-ops__desc">
          From diagnostics to deployment, HERMES is the first place to ask when you
          need clarity, speed, or a second perspective. He will explain, guide, and
          recommend — then return control to you.
        </p>
        <ul class="hh-ops__list">
          {capabilities.map((c) => (<li>{c}</li>))}
        </ul>
        <blockquote class="hh-ops__quote">
          “HERMES does not replace the Operator. He multiplies capability.”
          <cite>— HELIOS Engineering</cite>
        </blockquote>
      </div>

      <div class="hh-term" aria-label="Example HERMES session">
        <div class="hh-term__head">
          <span>HERMES SESSION</span>
          <span class="hh-term__active">ACTIVE <i></i></span>
        </div>
        <div class="hh-term__main">
          <div id="hermes-session-body" class="hh-term__body"></div>
          <div class="hh-term__side">
            <p class="hh-term__side-h">QUICK COMMANDS</p>
            <ul class="hh-term__cmds">
              {quickCmds.map((c) => (<li>{c}</li>))}
            </ul>
            <p class="hh-term__side-h">SESSION STATS</p>
            <dl class="hh-term__stats">
              {stats.map(([k, v]) => (<><dt>{k}</dt><dd>{v}</dd></>))}
            </dl>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       PHILOSOPHY PANELS
       ════════════════════════════════════════════════════════ -->
  <section class="hh-phil" aria-label="HERMES philosophy">
    <div class="container">
      <div class="hh-phil__grid">

        <div class="hh-panel">
          <h3 class="hh-panel__title">Integrated Into Aurora OS</h3>
          <p class="hh-panel__body">
            HERMES is always one command away. Type <code>hermes</code> at the prompt
            or prefix any question with <code>/hermes</code> in scripts.
          </p>
          <pre class="hh-mini">atlas &gt; hermes
HERMES online.

atlas &gt; <span class="hh-cur"></span></pre>
        </div>

        <div class="hh-panel">
          <h3 class="hh-panel__title">A Philosophy Of Control</h3>
          <p class="hh-panel__body">
            Aurora is built for those who demand precision. HERMES exists to support
            that standard.
          </p>
          <ul class="hh-phil__list">
            {philosophy.map((p) => (
              <li>
                <span class="hh-phil__icon" aria-hidden="true">
                  {p.icon === 'answer' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m8.5 12 2.5 2.5 4.5-5"/></svg>)}
                  {p.icon === 'tools' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.6 2.6-2-2 2.6-2.6z"/></svg>)}
                  {p.icon === 'focus' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V4h3M21 7V4h-3M3 17v3h3M21 17v3h-3"/><circle cx="12" cy="12" r="3"/></svg>)}
                  {p.icon === 'command' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 8 10 12 6 16"/><line x1="12" y1="16" x2="18" y2="16"/></svg>)}
                </span>
                <span>{p.text}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="hh-panel">
          <h3 class="hh-panel__title">Part Of The Helios Ecosystem</h3>
          <p class="hh-panel__body">
            Different systems. Same standard. HERMES for Aurora. IRIS for Solstice.
            Built by Helios. Trusted by Operators.
          </p>
          <div class="hh-eco">
            <div class="hh-eco__card">
              <span class="hh-eco__hermes" aria-hidden="true">H<br />E<br />R<br />M<br />E<br />S</span>
              <div>
                <p class="hh-eco__name hh-eco__name--hermes">HERMES</p>
                <p class="hh-eco__role">Aurora OS<br />Command Assistant</p>
              </div>
            </div>
            <a href={path('/iris')} class="hh-eco__card hh-eco__card--iris">
              <img class="hh-eco__orb" src={IRIS_EMBLEM} alt="" width="44" height="44" />
              <div>
                <p class="hh-eco__name hh-eco__name--iris">IRIS</p>
                <p class="hh-eco__role">Solstice OS<br />Intelligent Companion</p>
              </div>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       CLOSING BAND
       ════════════════════════════════════════════════════════ -->
  <section class="hh-close" aria-label="The Helios standard">
    <div class="container">
      <div class="hh-panel hh-close__panel">
        <span class="hh-close__glyph" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9.5"/><ellipse cx="12" cy="12" rx="4" ry="9.5"/><line x1="2.5" y1="12" x2="21.5" y2="12"/></svg>
        </span>
        <p class="hh-close__copy">Maximum capability. Minimal interference.<br />That is the Helios standard.</p>
        <div class="hh-close__cta">
          <a href="#" class="abtn abtn--solid">Explore Aurora OS
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href={path('/iris')} class="abtn abtn--ghost">Learn About IRIS</a>
        </div>
      </div>
    </div>
  </section>

  <Footer line="professional" />
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════
     HERMES PAGE — amber phosphor / terminal register
     ═══════════════════════════════════════════════════════════════ */
  .container {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  /* Amber buttons */
  .abtn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.8rem 1.4rem;
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all var(--duration-fast, 150ms) var(--ease-out, ease);
  }
  .abtn svg { transition: transform var(--duration-fast, 150ms) var(--ease-out, ease); }
  .abtn:hover svg { transform: translateX(3px); }
  .abtn--solid { color: #120c02; background: var(--helios-amber); box-shadow: 0 8px 24px rgba(255, 176, 0, 0.22); }
  .abtn--solid:hover { filter: brightness(1.08); }
  .abtn--ghost { color: var(--helios-amber); border: 1.5px solid var(--helios-amber); }
  .abtn--ghost:hover { background: rgba(255, 176, 0, 0.12); }

  /* Shared amber panel */
  .hh-panel {
    border: 1px solid rgba(255, 176, 0, 0.22);
    border-radius: 14px;
    padding: clamp(var(--space-5), 2.5vw, var(--space-6));
    background:
      radial-gradient(140% 110% at 50% 0%, rgba(255, 176, 0, 0.04), transparent 70%),
      rgba(255, 176, 0, 0.012);
  }

  /* ── HERO ──────────────────────────────────────────────────── */
  .hh { padding-block: clamp(var(--space-8), 5vh, var(--space-12)) var(--space-10); }
  .hh .container { max-width: min(1540px, 95vw); }
  .hh__inner {
    display: grid;
    grid-template-columns: minmax(210px, 0.7fr) minmax(0, 0.9fr) minmax(0, 1.95fr);
    gap: clamp(var(--space-5), 3vw, var(--space-9));
    align-items: center;
  }

  /* Vertical typewriter acronym */
  .hh-ac { display: flex; flex-direction: column; gap: 0.12em; }
  .hh-ac__row { display: flex; align-items: center; }
  .hh-ac__big {
    font-family: var(--font-terminal);
    font-size: clamp(3.4rem, 6vw, 5.2rem);
    line-height: 0.9;
    color: var(--helios-amber);
    text-shadow: 0 0 22px rgba(255, 176, 0, 0.42);
  }
  .hh-ac__rest {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    width: 0;
    font-family: var(--font-terminal);
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    color: rgba(255, 176, 0, 0.82);
    animation: hh-type 0.5s steps(var(--n)) var(--d) forwards;
  }
  @keyframes hh-type { to { width: calc((var(--n) + 0.4) * 1ch); } }
  .hh-ac__caret {
    display: inline-block;
    width: 0.55ch;
    height: 1.1em;
    margin-left: 2px;
    background: var(--helios-amber);
    opacity: 0;
    animation: hh-blink 1s step-end 3.9s infinite;
  }
  @keyframes hh-blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

  .hh__title {
    font-family: var(--font-terminal);
    font-weight: 400;
    font-size: clamp(2.2rem, 3.6vw, 3.2rem);
    line-height: 1.02;
    text-transform: uppercase;
    color: var(--helios-amber);
    text-shadow: 0 0 22px rgba(255, 176, 0, 0.3);
    margin-bottom: var(--space-4);
  }
  .hh__desc {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    line-height: 1.75;
    color: var(--text-secondary, rgba(255, 240, 220, 0.72));
    margin-bottom: var(--space-4);
  }
  .hh__pull {
    font-family: var(--font-mono);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--helios-amber);
    margin-bottom: var(--space-6);
  }
  .hh__cta { display: flex; flex-wrap: wrap; gap: var(--space-4); }

  .hh__image {
    width: 100%;
    border-radius: 10px;
    background: radial-gradient(58% 58% at 50% 45%, rgba(255, 176, 0, 0.07), transparent 72%);
  }
  .hh__image img { display: block; width: 100%; height: auto; border-radius: 10px; }

  /* ── CAPABILITY CARDS ──────────────────────────────────────── */
  .hh-feat { padding-block: var(--space-8); }
  .hh-feat__grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-5); }
  .hh-card {
    border: 1px solid rgba(255, 176, 0, 0.2);
    border-radius: 12px;
    padding: var(--space-5);
    background: rgba(255, 176, 0, 0.012);
  }
  .hh-card__icon { display: block; width: 30px; height: 30px; color: var(--helios-amber); margin-bottom: var(--space-4); }
  .hh-card__icon svg { width: 100%; height: 100%; }
  .hh-card__title { font-family: var(--font-mono); font-size: 0.84rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--helios-amber); margin-bottom: var(--space-3); line-height: 1.3; }
  .hh-card__body { font-family: var(--font-mono); font-size: 0.82rem; line-height: 1.7; color: var(--text-secondary, rgba(255, 240, 220, 0.7)); }

  /* ── BUILT FOR OPERATORS ───────────────────────────────────── */
  .hh-ops { padding-block: var(--space-8); }
  .hh-ops__inner { display: grid; grid-template-columns: 0.85fr 1.3fr; gap: clamp(var(--space-6), 3vw, var(--space-9)); align-items: start; }
  .hh-ops__title { font-family: var(--font-terminal); font-weight: 400; font-size: clamp(1.8rem, 3vw, 2.6rem); line-height: 1.05; text-transform: uppercase; color: var(--helios-amber); text-shadow: 0 0 20px rgba(255, 176, 0, 0.28); margin-bottom: var(--space-4); }
  .hh-ops__desc { font-family: var(--font-mono); font-size: 0.88rem; line-height: 1.75; color: var(--text-secondary, rgba(255, 240, 220, 0.7)); margin-bottom: var(--space-5); }
  .hh-ops__list { list-style: none; margin-bottom: var(--space-5); }
  .hh-ops__list li { font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.5; color: var(--text-primary, #f3e9da); padding: 4px 0 4px 1.4em; position: relative; }
  .hh-ops__list li::before { content: ">"; position: absolute; left: 0; color: var(--helios-amber); }
  .hh-ops__quote { border-left: 2px solid rgba(255, 176, 0, 0.5); padding: 4px 0 4px var(--space-4); font-family: var(--font-mono); font-size: 0.9rem; line-height: 1.6; color: var(--text-secondary, rgba(255, 240, 220, 0.78)); }
  .hh-ops__quote cite { display: block; margin-top: var(--space-2); font-style: normal; font-size: 0.78rem; color: var(--helios-amber); }

  /* Live session terminal */
  .hh-term {
    border: 1px solid rgba(255, 176, 0, 0.3);
    border-radius: 12px;
    overflow: hidden;
    background: #0a0805;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
  }
  .hh-term__head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.6rem 0.95rem;
    border-bottom: 1px solid rgba(255, 176, 0, 0.2);
    font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.14em;
    color: var(--helios-amber);
    background: rgba(255, 176, 0, 0.05);
  }
  .hh-term__active { display: inline-flex; align-items: center; gap: 6px; font-size: 0.66rem; }
  .hh-term__active i { width: 7px; height: 7px; border-radius: 50%; background: var(--helios-amber); box-shadow: 0 0 8px var(--helios-amber); animation: hh-blink 1.4s step-end infinite; }
  .hh-term__main { display: grid; grid-template-columns: 1fr 0.42fr; }
  .hh-term__body {
    min-height: 340px;
    max-height: 360px;
    overflow-y: auto;
    padding: var(--space-4);
    font-family: var(--font-mono);
  }
  .ht { font-size: 0.78rem; line-height: 1.65; white-space: pre-wrap; word-break: break-word; }
  .ht--p { color: var(--helios-amber); }
  .ht--o { color: #e4d4b2; }
  .ht--h { color: rgba(255, 176, 0, 0.92); }
  .ht--h2 { color: rgba(255, 176, 0, 0.62); }
  .ht--sp { height: 0.5em; }
  .ht-cur, .hh-cur {
    display: inline-block; width: 0.55ch; height: 1em;
    background: var(--helios-amber); vertical-align: text-bottom;
    animation: hh-blink 1s step-end infinite;
  }
  .hh-term__side {
    border-left: 1px solid rgba(255, 176, 0, 0.18);
    padding: var(--space-4);
    background: rgba(255, 176, 0, 0.02);
  }
  .hh-term__side-h { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.12em; color: rgba(255, 176, 0, 0.75); margin-bottom: var(--space-3); }
  .hh-term__side-h + * { margin-bottom: var(--space-5); }
  .hh-term__cmds { list-style: none; }
