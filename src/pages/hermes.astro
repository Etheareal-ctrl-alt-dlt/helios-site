    .hh-ac__caret, .hh-term__active i, .ht-cur, .hh-cur { animation: none; }
  }
</style>

<script>
  // HERMES session — types itself out on scroll-into-view.
  const body = document.getElementById('hermes-session-body');
  if (body) {
    const lines = [
      { cls: 'p',  text: 'atlas > hermes' },
      { cls: 'h',  text: 'HERMES online.' },
      { cls: 'sp', text: '' },
      { cls: 'o',  text: 'Operator: how do I mount a remote drive read-only?' },
      { cls: 'h',  text: 'HERMES: Use the mount command with the -o ro option. Example:' },
      { cls: 'h2', text: '    mount -o ro 192.168.1.45:/data /mnt/remote' },
      { cls: 'sp', text: '' },
      { cls: 'o',  text: 'Operator: any prerequisites?' },
      { cls: 'h',  text: 'HERMES: Ensure the network is reachable and the user has read permissions on the remote path.' },
      { cls: 'sp', text: '' },
      { cls: 'o',  text: 'Operator: create a one-line command for that' },
      { cls: 'h',  text: 'HERMES:' },
      { cls: 'h2', text: '    mount -o ro 192.168.1.45:/data /mnt/remote' },
      { cls: 'sp', text: '' },
      { cls: 'o',  text: 'Operator: thank you' },
      { cls: 'h',  text: "HERMES: You're welcome, Operator." },
    ];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let started = false;

    function addPrompt() {
      const p = document.createElement('div');
      p.className = 'ht ht--p';
      p.innerHTML = 'atlas &gt; <span class="ht-cur"></span>';
      body.appendChild(p);
      body.scrollTop = body.scrollHeight;
    }

    function run() {
      if (started) return;
      started = true;
      if (reduce) {
        lines.forEach((l) => {
          const d = document.createElement('div');
          d.className = 'ht ht--' + l.cls;
          d.textContent = l.text;
          body.appendChild(d);
        });
        addPrompt();
        return;
      }
      let li = 0;
      function nextLine() {
        if (li >= lines.length) { addPrompt(); return; }
        const l = lines[li++];
        const d = document.createElement('div');
        d.className = 'ht ht--' + l.cls;
        body.appendChild(d);
        if (!l.text) { setTimeout(nextLine, 110); return; }
        let ci = 0;
        (function typeChar() {
          d.textContent = l.text.slice(0, ++ci);
          body.scrollTop = body.scrollHeight;
          if (ci < l.text.length) setTimeout(typeChar, 11);
          else setTimeout(nextLine, 150);
        })();
      }
      nextLine();
    }

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { run(); io.disconnect(); } });
    }, { threshold: 0.25 });
    io.observe(body);
  }
</script>
