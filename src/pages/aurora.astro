---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import OSNav from '../components/OSNav.astro';
import Footer from '../components/Footer.astro';
import { path } from '../utils/url';

// ── Four feature cards ────────────────────────────────────────
const features = [
  { icon: 'terminal', title: 'Command First',     body: 'Every workflow begins at the prompt. Commands are short, mnemonic, and made for speed.' },
  { icon: 'layers',   title: 'Modular by Design', body: 'Chain commands, combine tools, and build repeatable workflows with precision and control.' },
  { icon: 'gauge',    title: 'Built for Speed',   body: 'Minimal overhead keeps the system immediate and responsive, from boot to execution.' },
  { icon: 'caduceus', title: 'HERMES Ready',      body: 'Ask HERMES for help, diagnostics, or guidance. Control stays with you, always.' },
];

// ── The Aurora command suite ──────────────────────────────────
const commandGroups = [
  { head: 'Productivity', cmds: ['notes', 'todo', 'weather'] },
  { head: 'System',       cmds: ['sysinfo', 'fetch', 'about', 'helios', 'wifi', 'bt', 'poweroff'] },
  { head: 'Utilities',    cmds: ['menu', 'clear', 'ls', 'cd'] },
  { head: 'Service',      cmds: ['hermes', 'apollo', 'council'] },
];

// ── Aurora principles ─────────────────────────────────────────
const principles = [
  { icon: 'assumptions', title: 'No Assumptions', body: 'Aurora assumes you know what you’re doing.' },
  { icon: 'takeover',    title: 'No Takeover',    body: 'You command. HERMES assists.' },
  { icon: 'distraction', title: 'No Distraction', body: 'No pop ups. No notifications. No noise.' },
  { icon: 'clarity',     title: 'Only Clarity',   body: 'Clear output. Clean tools. Clear results.' },
  { icon: 'operator',    title: 'Operator First', body: 'Aurora exists for one reason: to remove friction between you and the result.' },
];

// ── Hardware ──────────────────────────────────────────────────
const hardware = [
  { name: 'Atlas', role: 'Portable Command System', img: path('/images/products/atlas.png') },
  { name: 'Titan', role: 'Desktop Command System',  img: path('/images/products/titan.png') },
];

const missionLeft  = ['Secure by design', 'Minimal footprint', 'Offline capable'];
const missionRight = ['Ethernet or modem ready', 'Works when you do', 'Built by Helios. Trusted by Operators.'];
---

<BaseLayout
  title="Aurora OS — Helios Computer Corporation"
  description="Aurora OS — the command-driven operating system powering Atlas and Titan. Direct control. Zero noise. Built for professionals who know what they want."
  line="professional"
>
  <Nav current="os" line="professional" />
  <OSNav current="aurora" />

  <!-- ════════════════════════════════════════════════════════
       HERO
       ════════════════════════════════════════════════════════ -->
  <section class="au-hero" aria-labelledby="au-hero-title">
    <div class="container au-hero__inner">
      <div class="au-hero__lead">
        <p class="au-hero__eyebrow">Aurora OS</p>
        <h1 id="au-hero-title" class="au-hero__title">Direct Control.<br />Zero Noise.</h1>
        <p class="au-hero__desc">
          Aurora OS is the command-driven operating system powering Atlas and Titan.
          Built for professionals who know what they want, Aurora removes the layer
          between intent and execution. No visual clutter. No hand holding. Just the
          system, the command, and the result.
        </p>
        <div class="au-hero__cta">
          <a href="#suite" class="abtn abtn--solid">Explore Aurora OS
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href={path('/professional')} class="abtn abtn--ghost">See Atlas + Titan</a>
        </div>
      </div>
      <div class="au-hero__screen" aria-hidden="true">
        <img
          src={path('/images/os/aurora-screen.png')}
          alt="Aurora OS boot terminal"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
    <div class="container">
      <p class="au-hero__strip">&gt; Built for operators. Ready for any mission.</p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       FEATURE CARDS
       ════════════════════════════════════════════════════════ -->
  <section class="au-feat" aria-label="Aurora at a glance">
    <div class="container">
      <div class="au-feat__grid">
        {features.map((f) => (
          <div class="au-card">
            <span class="au-card__icon" aria-hidden="true">
              {f.icon === 'terminal' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><polyline points="7 9 10 12 7 15"/><line x1="13" y1="15" x2="17" y2="15"/></svg>)}
              {f.icon === 'layers' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 12 15 2 8.5 12 2"/><polyline points="2 14 12 20.5 22 14"/></svg>)}
              {f.icon === 'gauge' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 14a6 6 0 1 1 6-6"/><path d="M3 14a9 9 0 0 1 18 0"/><line x1="12" y1="14" x2="15.5" y2="9.5"/></svg>)}
              {f.icon === 'caduceus' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="4" x2="12" y2="21"/><circle cx="12" cy="3" r="1.4"/><path d="M7 6c2-1 3.2 0 5 1.6C13.8 6 15 5 17 6"/><path d="M9 9.5c0 2.2 6 2.2 6 4.4S9 16.1 9 18.3"/><path d="M15 9.5c0 2.2-6 2.2-6 4.4s6 2.2 6 4.4"/></svg>)}
            </span>
            <h3 class="au-card__title">{f.title}</h3>
            <p class="au-card__body">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       COMMAND SUITE  +  LIVE SYSTEM PREVIEW
       ════════════════════════════════════════════════════════ -->
  <section id="suite" class="au-suite" aria-label="Command suite and live system">
    <div class="container au-suite__inner">

      <div class="au-panel">
        <h2 class="au-panel__title">The Aurora Command Suite</h2>
        <p class="au-panel__sub">Everything you need. Nothing you don’t.</p>
        <div class="au-cmds">
          {commandGroups.map((g) => (
            <div class="au-cmds__col">
              <p class="au-cmds__head">{g.head}</p>
              <ul class="au-cmds__list">
                {g.cmds.map((c) => (<li>{c}</li>))}
              </ul>
            </div>
          ))}
        </div>
        <a href="#" class="au-textlink">View All Commands
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <div class="au-panel au-preview">
        <h2 class="au-panel__title">Live System Preview</h2>
        <div class="au-term">
          <div id="aurora-sys-body" class="au-term__body"></div>
        </div>
        <p class="au-preview__cap">Fast. Focused. Uncompromised.</p>
      </div>

    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       HERMES  +  PRINCIPLES
       ════════════════════════════════════════════════════════ -->
  <section class="au-mid" aria-label="HERMES and the Aurora principles">
    <div class="container au-mid__inner">

      <div class="au-panel au-hermes">
        <div class="au-hermes__head">
          <span class="au-hermes__emblem" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10.5"/><line x1="12" y1="5" x2="12" y2="19"/><circle cx="12" cy="4.3" r="1.1"/><path d="M8 6.6c1.6-0.8 2.6 0 4 1.3 1.4-1.3 2.4-2.1 4-1.3"/><path d="M9.5 9.4c0 1.9 5 1.9 5 3.8s-5 1.9-5 3.8"/><path d="M14.5 9.4c0 1.9-5 1.9-5 3.8s5 1.9 5 3.8"/></svg>
          </span>
          <div>
            <h2 class="au-hermes__title">HERMES — Assistance Without Interference</h2>
            <p class="au-hermes__desc">
              HERMES lives inside Aurora OS. He interprets commands, recommends next
              steps, and explains the system. He never takes over.
            </p>
          </div>
        </div>
        <pre class="au-mini">atlas &gt; hermes
HERMES online.

Operator: recommend next diagnostic
HERMES: Run: net.trace local gateway

Operator: create a backup of /data
HERMES: Run: tar -czf /data/backup-$(date +%F).tar.gz /data

Operator: thanks
HERMES: You're welcome, Operator.
atlas &gt; <span class="au-cur"></span></pre>
        <a href={path('/hermes')} class="au-textlink">Learn More About HERMES
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <div class="au-panel">
        <h2 class="au-panel__title">The Aurora Principles</h2>
        <ul class="au-prin">
          {principles.map((p) => (
            <li class="au-prin__item">
              <span class="au-prin__icon" aria-hidden="true">
                {p.icon === 'assumptions' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.8.4-1 .9-1 1.7"/><circle cx="12" cy="16.5" r="0.5" fill="currentColor"/></svg>)}
                {p.icon === 'takeover' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="8 12 11 15 16 9"/></svg>)}
                {p.icon === 'distraction' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><line x1="5.6" y1="5.6" x2="18.4" y2="18.4"/></svg>)}
                {p.icon === 'clarity' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/></svg>)}
                {p.icon === 'operator' && (<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.2"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/></svg>)}
              </span>
              <div>
                <p class="au-prin__title">{p.title}</p>
                <p class="au-prin__body">{p.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       HARDWARE  +  MISSION
       ════════════════════════════════════════════════════════ -->
  <section class="au-bottom" aria-label="Hardware and mission readiness">
    <div class="container au-bottom__inner">

      <div class="au-panel">
        <h2 class="au-panel__title">Built For Helios Hardware</h2>
        <p class="au-panel__sub">Aurora OS ships on the professional line.</p>
        <div class="au-hw">
          {hardware.map((h) => (
            <div class="au-hw__item">
              <div class="au-hw__imgwrap"><img src={h.img} alt={`Helios ${h.name}`} loading="lazy" decoding="async" /></div>
              <p class="au-hw__name">{h.name}</p>
              <p class="au-hw__role">{h.role}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="au-panel">
        <h2 class="au-panel__title">Ready For Any Mission</h2>
        <p class="au-panel__sub au-mission__lede">
          Aurora is stable, secure, and field ready. From diagnostics to deployment,
          from analysis to execution — Aurora stays out of your way.
        </p>
        <div class="au-mission__cols">
          <ul class="au-mission__list">{missionLeft.map((m) => (<li>{m}</li>))}</ul>
          <ul class="au-mission__list">{missionRight.map((m) => (<li>{m}</li>))}</ul>
        </div>
        <a href="#" class="abtn abtn--solid au-mission__cta">Explore Aurora OS
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

    </div>
  </section>

  <Footer line="professional" />
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════
     AURORA OS PAGE — amber phosphor / terminal register
     ═══════════════════════════════════════════════════════════════ */
  .container { width: 100%; max-width: 1200px; margin-inline: auto; padding-inline: var(--space-6); }

  .abtn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: 0.8rem 1.4rem; border-radius: 8px;
    font-family: var(--font-mono); font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none;
    transition: all var(--duration-fast, 150ms) var(--ease-out, ease);
  }
  .abtn svg { transition: transform var(--duration-fast, 150ms) var(--ease-out, ease); }
  .abtn:hover svg { transform: translateX(3px); }
  .abtn--solid { color: #120c02; background: var(--helios-amber); box-shadow: 0 8px 24px rgba(255, 176, 0, 0.22); }
  .abtn--solid:hover { filter: brightness(1.08); }
  .abtn--ghost { color: var(--helios-amber); border: 1.5px solid var(--helios-amber); }
  .abtn--ghost:hover { background: rgba(255, 176, 0, 0.12); }

  .au-textlink {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--helios-amber); text-decoration: none;
    border: 1px solid rgba(255, 176, 0, 0.4); border-radius: 8px;
    padding: 0.6rem 1.1rem; margin-top: var(--space-5);
  }
  .au-textlink:hover { background: rgba(255, 176, 0, 0.1); }
  .au-textlink svg { transition: transform var(--duration-fast, 150ms) var(--ease-out, ease); }
  .au-textlink:hover svg { transform: translateX(3px); }

  .au-panel {
    border: 1px solid rgba(255, 176, 0, 0.22); border-radius: 14px;
    padding: clamp(var(--space-5), 2.5vw, var(--space-7));
    background: radial-gradient(140% 110% at 50% 0%, rgba(255, 176, 0, 0.04), transparent 70%), rgba(255, 176, 0, 0.012);
  }
  .au-panel__title { font-family: var(--font-mono); font-size: 1rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--helios-amber); margin-bottom: var(--space-2); }
  .au-panel__sub { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-secondary, rgba(255, 240, 220, 0.7)); margin-bottom: var(--space-5); }

  /* ── HERO ──────────────────────────────────────────────────── */
  .au-hero { padding-block: clamp(var(--space-8), 5vh, var(--space-12)) var(--space-8); }
  .au-hero__inner { display: grid; grid-template-columns: 1fr 1.1fr; gap: clamp(var(--space-6), 4vw, var(--space-10)); align-items: center; }
  .au-hero__eyebrow { font-family: var(--font-mono); font-size: 0.82rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--helios-amber); margin-bottom: var(--space-4); }
  .au-hero__title { font-family: var(--font-terminal); font-weight: 400; font-size: clamp(2.8rem, 6vw, 5rem); line-height: 0.98; text-transform: uppercase; color: var(--helios-amber); text-shadow: 0 0 26px rgba(255, 176, 0, 0.32); margin-bottom: var(--space-5); }
  .au-hero__desc { font-family: var(--font-mono); font-size: 0.95rem; line-height: 1.8; color: var(--text-secondary, rgba(255, 240, 220, 0.72)); margin-bottom: var(--space-6); max-width: 48ch; }
  .au-hero__cta { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .au-hero__screen img { display: block; width: 100%; height: auto; }
  .au-hero__strip { font-family: var(--font-mono); font-size: 0.86rem; letter-spacing: 0.04em; color: rgba(255, 176, 0, 0.7); margin-top: var(--space-7); padding-top: var(--space-5); border-top: 1px solid rgba(255, 176, 0, 0.16); }

  /* ── FEATURE CARDS ─────────────────────────────────────────── */
  .au-feat { padding-block: var(--space-8); }
  .au-feat__grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-5); }
  .au-card { border: 1px solid rgba(255, 176, 0, 0.2); border-radius: 12px; padding: var(--space-5); background: rgba(255, 176, 0, 0.012); }
  .au-card__icon { display: block; width: 30px; height: 30px; color: var(--helios-amber); margin-bottom: var(--space-4); }
  .au-card__icon svg { width: 100%; height: 100%; }
  .au-card__title { font-family: var(--font-mono); font-size: 0.84rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--helios-amber); margin-bottom: var(--space-3); }
  .au-card__body { font-family: var(--font-mono); font-size: 0.82rem; line-height: 1.7; color: var(--text-secondary, rgba(255, 240, 220, 0.7)); }

  /* ── COMMAND SUITE + PREVIEW ───────────────────────────────── */
  .au-suite { padding-block: var(--space-8); }
  .au-suite__inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); align-items: stretch; }
  .au-cmds { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-4); }
  .au-cmds__head { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255, 176, 0, 0.75); margin-bottom: var(--space-3); padding-bottom: var(--space-2); border-bottom: 1px solid rgba(255, 176, 0, 0.18); }
  .au-cmds__list { list-style: none; }
  .au-cmds__list li { font-family: var(--font-mono); font-size: 0.85rem; line-height: 2; color: var(--text-primary, #f3e9da); }
  .au-cmds__list li::before { content: ""; }

  .au-preview { display: flex; flex-direction: column; }
  .au-term { flex: 1; border: 1px solid rgba(255, 176, 0, 0.3); border-radius: 10px; background: #0a0805; overflow: hidden; box-shadow: 0 14px 40px rgba(0, 0, 0, 0.4); }
  .au-term__body { min-height: 360px; padding: var(--space-4); font-family: var(--font-mono); }
  .at { font-size: 0.78rem; line-height: 1.7; white-space: pre-wrap; }
  .at--p { color: var(--helios-amber); }
  .at--hd { color: var(--helios-amber); border-bottom: 1px solid rgba(255,176,0,0.25); padding-bottom: 4px; margin-bottom: 4px; }
  .at--r { color: rgba(255, 176, 0, 0.85); }
  .au-bar { height: 9px; border-radius: 2px; background: rgba(255, 176, 0, 0.14); margin: 2px 0 6px; overflow: hidden; }
  .au-bar__fill { height: 100%; width: 0; background: var(--helios-amber); transition: width 600ms var(--ease-out, ease); }
  .at-cur, .au-cur { display: inline-block; width: 0.55ch; height: 1em; background: var(--helios-amber); vertical-align: text-bottom; animation: au-blink 1s step-end infinite; }
  @keyframes au-blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }
  .au-preview__cap { text-align: center; font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-secondary, rgba(255, 240, 220, 0.6)); margin-top: var(--space-4); }

  /* ── HERMES + PRINCIPLES ───────────────────────────────────── */
  .au-mid { padding-block: var(--space-8); }
  .au-mid__inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-5); align-items: stretch; }
  .au-hermes__head { display: flex; gap: var(--space-4); margin-bottom: var(--space-4); }
  .au-hermes__emblem { flex: none; width: 56px; height: 56px; color: var(--helios-amber); }
  .au-hermes__emblem svg { width: 100%; height: 100%; }
  .au-hermes__title { font-family: var(--font-mono); font-size: 0.92rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--helios-amber); margin-bottom: var(--space-2); line-height: 1.35; }
  .au-hermes__desc { font-family: var(--font-mono); font-size: 0.82rem; line-height: 1.65; color: var(--text-secondary, rgba(255, 240, 220, 0.7)); }
  .au-mini { font-family: var(--font-mono); font-size: 0.76rem; line-height: 1.7; color: var(--helios-amber); background: #0a0805; border: 1px solid rgba(255, 176, 0, 0.18); border-radius: 8px; padding: var(--space-4); margin: 0; white-space: pre-wrap; }

  .au-prin { list-style: none; }
  .au-prin__item { display: flex; gap: var(--space-3); padding: var(--space-3) 0; border-bottom: 1px solid rgba(255, 176, 0, 0.1); }
  .au-prin__item:last-child { border-bottom: none; }
  .au-prin__icon { flex: none; width: 26px; height: 26px; color: var(--helios-amber); }
  .au-prin__icon svg { width: 100%; height: 100%; }
  .au-prin__title { font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--helios-amber); margin-bottom: 2px; }
  .au-prin__body { font-family: var(--font-mono); font-size: 0.8rem; line-height: 1.55; color: var(--text-secondary, rgba(255, 240, 220, 0.7)); }

  /* ── HARDWARE + MISSION ────────────────────────────────────── */
  .au-bottom { padding-block: var(--space-8) var(--space-12); }
  .au-bottom__inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); align-items: stretch; }
  .au-hw { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); }
  .au-hw__imgwrap { aspect-ratio: 4 / 3; display: grid; place-items: center; margin-bottom: var(--space-3); }
  .au-hw__imgwrap img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .au-hw__name { font-family: var(--font-mono); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--helios-amber); }
  .au-hw__role { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-secondary, rgba(255, 240, 220, 0.6)); }
  .au-mission__lede { line-height: 1.7; }
  .au-mission__cols { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); margin-bottom: var(--space-5); }
  .au-mission__list { list-style: none; }
  .au-mission__list li { font-family: var(--font-mono); font-size: 0.82rem; line-height: 1.7; color: var(--text-primary, #f3e9da); padding-left: 1.4em; position: relative; }
  .au-mission__list li::before { content: ">"; position: absolute; left: 0; color: var(--helios-amber); }
  .au-mission__cta { margin-top: var(--space-2); }

  /* ═══════════════════════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════════════════════ */
  @media (max-width: 1000px) {
    .au-hero__inner { grid-template-columns: 1fr; }
    .au-hero__screen { max-width: 640px; }
    .au-feat__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .au-suite__inner, .au-mid__inner, .au-bottom__inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .au-feat__grid { grid-template-columns: 1fr; }
    .au-cmds { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .au-hermes__head { flex-direction: column; }
    .au-mission__cols { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .at-cur, .au-cur { animation: none; }
    .au-bar__fill { transition: none; }
  }
</style>

<script>
  // Aurora "sysinfo" — types itself out on scroll-into-view (real values).
  const body = document.getElementById('aurora-sys-body');
  if (body) {
    const lines = [
      { cls: 'p',  text: 'atlas > sysinfo' },
      { cls: 'hd', text: 'HELIOS ATLAS — SYSTEM INFORMATION' },
      { cls: 'r',  text: 'Hostname ........... atlas' },
      { cls: 'r',  text: 'OS ................. Aurora OS v1.0' },
      { cls: 'r',  text: 'Kernel ............. 6.12.75+rpt-rpi-2712' },
      { cls: 'r',  text: 'Uptime ............. 2 minutes' },
      { cls: 'r',  text: 'CPU Temp ........... 41.1°C' },
      { cls: 'r',  text: 'CPU Usage .......... 1.6%' },
      { cls: 'r',  text: 'Memory ............. 300MB / 8058MB (3.7%)', bar: 3.7 },
      { cls: 'r',  text: 'Storage ............ 4.3G / 58G (8%)', bar: 8 },
      { cls: 'r',  text: 'Wi-Fi SSID ......... NERV' },
      { cls: 'r',  text: 'IP Address ......... 10.0.0.210' },
    ];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let started = false;

    function addBar(pct) {
      const wrap = document.createElement('div');
      wrap.className = 'au-bar';
      const fill = document.createElement('div');
      fill.className = 'au-bar__fill';
      wrap.appendChild(fill);
      body.appendChild(wrap);
      requestAnimationFrame(() => { fill.style.width = pct + '%'; });
    }
    function addPrompt() {
      const p = document.createElement('div');
      p.className = 'at at--p';
      p.innerHTML = 'atlas &gt; <span class="at-cur"></span>';
      body.appendChild(p);
      body.scrollTop = body.scrollHeight;
    }
    function render(instant) {
      let i = 0;
      function nextLine() {
        if (i >= lines.length) { addPrompt(); return; }
        const l = lines[i++];
        const d = document.createElement('div');
        d.className = 'at at--' + l.cls;
        body.appendChild(d);
        const done = () => { if (l.bar !== undefined) addBar(l.bar); setTimeout(nextLine, l.bar !== undefined ? 260 : 90); };
        if (instant) { d.textContent = l.text; done(); return; }
        let c = 0;
        (function type() {
          d.textContent = l.text.slice(0, ++c);
          body.scrollTop = body.scrollHeight;
          if (c < l.text.length) setTimeout(type, 10);
          else done();
        })();
      }
      nextLine();
    }
    const io = new IntersectionObserver((es) => {
      es.forEach((e) => { if (e.isIntersecting && !started) { started = true; render(reduce); io.disconnect(); } });
    }, { threshold: 0.25 });
    io.observe(body);
  }
</script>
