<script>
  // Tap-to-play on touch / click: toggles the same state hover uses.
  document.querySelectorAll('.surface').forEach((card) => {
    card.addEventListener('click', () => card.classList.toggle('is-playing'));
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        card.classList.toggle('is-playing');
      }
    });
  });
</script>
