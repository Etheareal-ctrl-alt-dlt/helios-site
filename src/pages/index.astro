---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { path } from '../utils/url';
---

<BaseLayout
  title="Helios Computer Corporation"
  description="From professional command systems to personal computing made simple. Helios builds machines that meet their Operators where they are."
  line="consumer"
>
  <Nav line="homepage" current="home" />

  <section class="hp-hero" aria-labelledby="hp-hero-title">
    {/* CENTER — appears first in source so it stacks above on mobile */}
    <div class="hp-hero__center">
      <div class="hp-hero__center-inner">
        <div class="hp-hero__brand" aria-label="Helios Computer Corporation">
          <span class="hp-hero__brand-name">HELIOS</span>
          <span class="hp-hero__brand-sub">Computer Corporation<sup>®</sup></span>
          <span class="hp-hero__brand-rule" aria-hidden="true"></span>
        </div>

        <h1 id="hp-hero-title" class="hp-hero__title">
          Power, shaped for<br />the Operator.
        </h1>

        <p class="hp-hero__lede">
          From professional command systems to personal computing made
          simple, Helios builds machines that meet their Operators where
          they are.
        </p>

        <div class="hp-hero__ctas">
          <a href={path('/professional')} class="hp-cta hp-cta--pro">
            <span>Explore Professional</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.25"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
          <a href={path('/consumer')} class="hp-cta hp-cta--consumer">
            <span>Explore Consumer</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.25"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    {/* TWO-PANEL BACKGROUND */}
    <div class="hp-hero__panels">
      <article class="hp-hero__panel hp-hero__panel--pro">
        <img
          class="hp-hero__panel-bg"
          src={path('/images/products/professional-home.png')}
          alt="Helios Atlas and Titan workstations"
          loading="eager"
          decoding="async"
        />
        <div class="hp-hero__panel-overlay hp-hero__panel-overlay--pro" aria-hidden="true"></div>
        <div class="hp-hero__panel-content">
          <p class="hp-hero__panel-eyebrow hp-hero__panel-eyebrow--pro">
            <span class="hp-hero__panel-eyebrow-mark">█</span>
            Aurora&nbsp;OS
          </p>
          <h2 class="hp-hero__panel-title hp-hero__panel-title--pro">
            Power to the<br />Professional.
          </h2>
          <p class="hp-hero__panel-lede">
            Built for serious work.<br />
            Engineered for control.<br />
            Ready for anything.
          </p>
        </div>
      </article>

      <article class="hp-hero__panel hp-hero__panel--consumer">
        <img
          class="hp-hero__panel-bg"
          src={path('/images/products/consumer-home.png')}
          alt="Helios Nova and Genesis"
          loading="eager"
          decoding="async"
        />
        <div class="hp-hero__panel-overlay hp-hero__panel-overlay--consumer" aria-hidden="true"></div>
        <div class="hp-hero__panel-content">
          <p class="hp-hero__panel-eyebrow hp-hero__panel-eyebrow--consumer">
            Solstice&nbsp;OS
          </p>
          <h2 class="hp-hero__panel-title hp-hero__panel-title--consumer">
            Power<br />Made Simple.
          </h2>
          <p class="hp-hero__panel-lede">
            Designed for real life.<br />
            Intuitive. Connected.<br />
            Made for you.
          </p>
        </div>
      </article>
    </div>
  </section>

  <Footer line="consumer" />
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════
     HOMEPAGE HERO
     Three typographic identities:
       PROFESSIONAL → IBM Plex Mono, amber (Aurora OS terminal voice)
       COMPANY      → IBM Plex Serif, white (editorial / corporate)
       CONSUMER     → Nunito Black, gradient (warm rounded sans)
     ═══════════════════════════════════════════════════════════════ */
  .hp-hero {
    position: relative;
    min-height: clamp(720px, 100vh, 960px);
    overflow: hidden;
    background: #050510;
  }

  /* ── Two-panel layer (sits behind center overlay) ──────────── */
  .hp-hero__panels {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .hp-hero__panel {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    align-content: start;
    padding-block: clamp(var(--space-7), 7vh, var(--space-10));
    overflow: hidden;
  }

  .hp-hero__panel-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* Bias toward the bottom of each image so products stay visible */
  .hp-hero__panel--pro .hp-hero__panel-bg      { object-position: center 65%; }
  .hp-hero__panel--consumer .hp-hero__panel-bg { object-position: center 60%; }

  /* Per-side overlay — top dark for headline readability */
  .hp-hero__panel-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .hp-hero__panel-overlay--pro {
    background: linear-gradient(
      180deg,
      rgba(5, 5, 12, 0.85) 0%,
      rgba(5, 5, 12, 0.5) 22%,
      rgba(5, 5, 12, 0.12) 55%,
      rgba(5, 5, 12, 0.0) 100%
    );
  }
  .hp-hero__panel-overlay--consumer {
    background: linear-gradient(
      180deg,
      rgba(10, 10, 24, 0.78) 0%,
      rgba(10, 10, 24, 0.42) 22%,
      rgba(10, 10, 24, 0.1) 55%,
      rgba(10, 10, 24, 0.0) 100%
    );
  }

  /* ── Side panel content — pushed INWARD toward center ────── */
  .hp-hero__panel-content {
    position: relative;
    z-index: 2;
    width: clamp(240px, 26vw, 340px);
  }

  /* Pro content pinned to the inner (right) edge of pro panel,
     consumer content pinned to inner (left) edge of consumer panel.
     The clamp() margin pulls them away from the central vignette
     spotlight so they get their own breathing room. */
  .hp-hero__panel--pro .hp-hero__panel-content {
    margin-left: auto;
    margin-right: clamp(var(--space-7), 6vw, var(--space-12));
    text-align: left;
  }
  .hp-hero__panel--consumer .hp-hero__panel-content {
    margin-right: auto;
    margin-left: clamp(var(--space-7), 6vw, var(--space-12));
    text-align: right;
  }

  /* ── Panel eyebrow tags (Aurora OS / Solstice OS) ────────── */
  .hp-hero__panel-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.8);
  }
  .hp-hero__panel-eyebrow--pro {
    color: var(--helios-amber);
  }
  .hp-hero__panel-eyebrow--consumer {
    color: var(--pink);
    /* In RTL alignment, the eyebrow still reads naturally — but
       the flex direction follows text-align: right via auto. */
  }
  .hp-hero__panel-eyebrow-mark {
    font-size: 0.6em;
    line-height: 1;
    transform: translateY(-1px);
  }

  /* ── Panel titles ────────────────────────────────────────── */
  .hp-hero__panel-title {
    line-height: 1.05;
    margin-bottom: var(--space-4);
  }

  /* PRO title — terminal/monospace voice */
  .hp-hero__panel-title--pro {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: clamp(1.1rem, 1.8vw, 1.7rem);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--helios-amber);
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.7);
  }

  /* CONSUMER title — warm rounded gradient */
  .hp-hero__panel-title--consumer {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: clamp(1.5rem, 2.4vw, 2.1rem);
    letter-spacing: -0.01em;
    text-transform: uppercase;
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 2px 12px rgba(0, 0, 0, 0.65));
  }

  /* Side panel ledes */
  .hp-hero__panel-lede {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.8;
    letter-spacing: 0.01em;
    color: var(--text-primary);
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.75);
  }

  /* ═══════════════════════════════════════════════════════════════
     CENTER — corporate / editorial voice
     ═══════════════════════════════════════════════════════════════ */
  .hp-hero__center {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: grid;
    justify-items: center;
    align-items: start;
    /* Push content down past the sticky nav, but keep it in the upper
       half of the hero so HELIOS reads as a "letterhead" mark first */
    padding-top: clamp(170px, 18vh, 240px);
    /* Tighter radial vignette so the side headlines get breathing
       room outside the center spotlight */
    background: radial-gradient(
      ellipse 38% 65% at center 45%,
      rgba(5, 5, 14, 0.92) 0%,
      rgba(5, 5, 14, 0.78) 35%,
      rgba(5, 5, 14, 0.35) 65%,
      transparent 85%
    );
    pointer-events: none;
  }

  .hp-hero__center-inner {
    pointer-events: auto;
    max-width: 640px;
    text-align: center;
    padding-inline: var(--space-6);
  }

  /* ── HELIOS brand mark — corporate letterhead ─────────────── */
  .hp-hero__brand {
    display: grid;
    justify-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-10);  /* generous gap before headline */
  }

  .hp-hero__brand-name {
    font-family: var(--font-corporate);
    font-weight: 800;
    font-size: clamp(2.4rem, 4vw, 3.4rem);  /* bigger */
    letter-spacing: 0.32em;
    text-indent: 0.32em;
    color: var(--text-primary);
    line-height: 1;
  }

  .hp-hero__brand-sub {
    font-family: var(--font-mono);
    font-size: 0.8rem;  /* slightly bigger */
    font-weight: var(--weight-medium);
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--text-secondary);
    line-height: 1;
  }
  .hp-hero__brand-sub sup {
    font-size: 0.7em;
    margin-left: 1px;
    opacity: 0.85;
  }

  /* Thin amber-tinted divider beneath the brand mark */
  .hp-hero__brand-rule {
    display: block;
    width: 60px;
    height: 1px;
    margin-top: var(--space-6);
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 176, 0, 0.45),
      transparent
    );
  }

  /* ── Main headline ───────────────────────────────────────── */
  .hp-hero__title {
    font-family: var(--font-corporate);
    font-weight: 700;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--space-10);  /* MUCH more space before lede */
    text-shadow: 0 4px 32px rgba(0, 0, 0, 0.5);
  }

  /* ── Lede ───────────────────────────────────────────────── */
  .hp-hero__lede {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: var(--space-8);
    max-width: 480px;
    margin-inline: auto;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.6);
  }

  /* ── Dual CTAs ──────────────────────────────────────────── */
  .hp-hero__ctas {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hp-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border: 1.5px solid currentColor;
    border-radius: 10px;
    background: rgba(5, 5, 14, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: all var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }
  .hp-cta:hover { transform: translateY(-1px); }
  .hp-cta:active { transform: translateY(0); }
  .hp-cta svg { transition: transform var(--duration-fast) var(--ease-out); }
  .hp-cta:hover svg { transform: translateX(3px); }

  .hp-cta--pro {
    color: var(--helios-amber);
  }
  .hp-cta--pro:hover {
    background: var(--helios-amber);
    color: #050505;
  }

  .hp-cta--consumer {
    color: var(--pink);
  }
  .hp-cta--consumer:hover {
    background: var(--pink);
    color: var(--bg-deep);
  }

  /* ═══════════════════════════════════════════════════════════════
     ENTRANCE ANIMATIONS
     ═══════════════════════════════════════════════════════════════ */
  .hp-hero__panel       { animation: fade-in 1100ms var(--ease-out) 100ms both; }
  .hp-hero__brand       { animation: fade-up 800ms var(--ease-out) 350ms both; }
  .hp-hero__title       { animation: fade-up 900ms var(--ease-out) 500ms both; }
  .hp-hero__lede        { animation: fade-up 1000ms var(--ease-out) 700ms both; }
  .hp-hero__ctas        { animation: fade-up 1100ms var(--ease-out) 900ms both; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hp-hero__panel,
    .hp-hero__brand,
    .hp-hero__title,
    .hp-hero__lede,
    .hp-hero__ctas {
      animation: none;
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     RESPONSIVE — stack on narrow viewports
     ═══════════════════════════════════════════════════════════════ */
  @media (max-width: 900px) {
    .hp-hero {
      min-height: auto;
    }

    .hp-hero__center {
      position: relative;
      inset: auto;
      padding-block: var(--space-12) var(--space-10);
      background:
        radial-gradient(
          ellipse 90% 60% at center,
          rgba(255, 111, 168, 0.12) 0%,
          transparent 70%
        ),
        var(--bg-deep);
    }

    .hp-hero__panels {
      position: relative;
      inset: auto;
      grid-template-columns: 1fr;
    }

    .hp-hero__panel {
      min-height: 460px;
      padding: var(--space-7) var(--space-5) var(--space-6);
    }

    .hp-hero__panel-content {
      width: 100%;
    }
    .hp-hero__panel--pro .hp-hero__panel-content,
    .hp-hero__panel--consumer .hp-hero__panel-content {
      margin-inline: 0;
      text-align: left;
    }

    .hp-hero__ctas {
      flex-direction: column;
      align-items: stretch;
    }
    .hp-cta {
      justify-content: center;
    }
  }
</style>
