---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import FeatureItem from '../components/FeatureItem.astro';
import { path } from '../utils/url';

const products = [
  {
    name: 'NOVA',
    subtitle: 'All-In-One System',
    accent: 'pink' as const,
    description: 'The heart of your home. Beautifully integrated. Effortlessly simple. Nova brings people, entertainment, and creativity together.',
    specs: [
      '15.4" TFT LCD (4:3)',
      '1280 x 1024 Resolution',
      'Broadcom BCM2712 System-on-Chip (SoC)',
      '16GB RAM',
      '128 / 256 / 512GB MicroSD Storage Options',
      'Variety of IO Ports',
      'Integrated Stereo Speakers',
      'Solstice OS',
    ],
    cta: { label: 'Buy Nova', href: path('/products/nova') },
    image: path('/images/products/nova.png'),
    imageAlt: 'Helios Nova all-in-one workstation',
  },
  {
    name: 'GENESIS',
    subtitle: 'Portable Computer',
    accent: 'purple' as const,
    description: 'Your world. On the move. Lightweight, capable, and ready for whatever comes next.',
    specs: [
      'Broadcom BCM2712 System-on-Chip (SoC)',
      '8GB RAM',
      '128 / 256 / 512GB Storage Options',
      '13.3" 2K Display (2560 x 1440)',
      'Variety of IO Ports',
      'Light and Durable Design',
      'Solstice OS',
      'Up to 4.5 Hours Battery Life',
    ],
    cta: { label: 'Buy Genesis', href: path('/products/genesis') },
    image: path('/images/products/genesis.png'),
    imageAlt: 'Helios Genesis portable computer',
  },
];

const irisFeatures = [
  'Voice & Touch Activated',
  'Smart Home Integration',
  'Organizer & Reminders',
  'Media & Entertainment',
  'Internet & Communication',
  'Learning & Recommendations',
  'Always Learning. Always Helpful.',
];

const valueProps = [
  {
    title: 'Beautiful by Design',
    description: 'Elegant systems that look as good as they perform.',
    icon: 'heart' as const,
    accent: 'pink' as const,
  },
  {
    title: 'Easy to Live With',
    description: 'Intuitive Solstice OS makes everything feel natural.',
    icon: 'leaf' as const,
    accent: 'mint' as const,
  },
  {
    title: 'Stay Connected',
    description: 'Built-in networking keeps you close to what matters most.',
    icon: 'wifi' as const,
    accent: 'purple' as const,
  },
  {
    title: 'Safe and Secure',
    description: 'Helios systems keep your privacy and data protected.',
    icon: 'shield' as const,
    accent: 'blue' as const,
  },
];
---

<BaseLayout
  title="Consumer Line — Helios Computer Corporation"
  description="Power Made Simple. Computers that fit beautifully into your life. Meet Nova, Genesis, and the IRIS intelligent assistant."
  line="consumer"
>
  <Nav current="consumer" line="consumer" />

  <!-- ════════════════════════════════════════════════════════
       HERO — full-bleed Nova lifestyle shot with text overlay
       ════════════════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-title">
    <img
      src={path('/images/products/nova-hero.png')}
      alt="The Helios Nova in a warm home setting"
      class="hero__bg"
    />
    <div class="hero__overlay" aria-hidden="true"></div>

    <div class="container hero__inner">
      <div class="hero__copy">
        <p class="eyebrow hero__eyebrow">Helios Consumer Line</p>
        <h1 id="hero-title" class="hero__title">
          <span>Power</span>
          <span class="gradient-text">Made Simple.</span>
        </h1>

        <div class="hero__rule" aria-hidden="true"></div>

        <p class="hero__lede">
          Welcome to the Helios Consumer Line.<br/>
          Computers that fit beautifully into<br/>
          your life, not the other way around.<br/>
          Intuitive. Connected. Personal.<br/>
          From the family room to the studio,<br/>
          Helios makes technology natural.
        </p>

        <a href="#products" class="hero__more">
          <span>Simple. Personal. Helios.</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="13 17 18 12 13 7"/>
            <polyline points="6 17 11 12 6 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       PRODUCT GRID
       ════════════════════════════════════════════════════════ -->
  <section id="products" class="products">
    <div class="container">
      <div class="products__grid">
        {products.map((p) => (
          <ProductCard {...p} />
        ))}

        <!-- IRIS — same card shell, custom media (the emblem), and
             "Learn About" CTA instead of "Buy". -->
        <article class="iris-card">
          <header class="iris-card__header">
            <h2 class="iris-card__name">IRIS</h2>
            <p class="iris-card__subtitle">Intelligent Assistant</p>
          </header>

          <div class="iris-card__media">
            <img
              src={path('/images/logos/iris-emblem.png')}
              alt="IRIS emblem — the iridescent ring of the Helios consumer AI companion"
              class="iris-card__emblem"
            />
          </div>

          <p class="iris-card__desc">
            IRIS is your personal companion, built into every Helios system.
            One touch. One voice. Always there.
          </p>

          <ul class="iris-card__specs">
            {irisFeatures.map((f) => (
              <li>
                <svg class="spec-star" width="11" height="11" viewBox="0 0 12 12" aria-hidden="true">
                  <path d="M6 0 L7.1 4.9 L12 6 L7.1 7.1 L6 12 L4.9 7.1 L0 6 L4.9 4.9 Z" fill="currentColor"/>
                </svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <a href={path('/iris')} class="iris-card__cta">
            <span>Learn About IRIS</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       VALUE PROPS — full-bleed band across the bottom of the page
       ════════════════════════════════════════════════════════ -->
  <section class="value-props">
    <div class="container">
      <div class="value-props__grid">
        {valueProps.map((vp) => (
          <FeatureItem {...vp} />
        ))}
      </div>
    </div>
  </section>

  <Footer line="consumer" />
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════════════
     HERO — full-bleed photo with gradient overlay for legibility
     ══════════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    width: 100%;
    min-height: clamp(580px, 70vh, 840px);
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Bias the visible window UP and slightly right so we see more
       of the top of the photo (Nova's full top bezel + space above)
       while keeping the Nova itself centered horizontally. */
    object-position: 55% 32%;
    z-index: 0;
    /* The PNG ships with a black backdrop already — it blends with
       the page edges naturally, no vignette needed here. */
    animation: hero-bg-in 1200ms var(--ease-out) both;
  }

  /* The overlay does two jobs:
     1. Dark wash on the LEFT, fading to clear on the RIGHT — keeps
        text readable while letting the Nova / lamp stay visible.
     2. Soft dark fade at the BOTTOM — smooth handoff to the next
        section without a hard edge. */
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        90deg,
        rgba(10, 10, 24, 0.95) 0%,
        rgba(10, 10, 24, 0.82) 18%,
        rgba(10, 10, 24, 0.50) 40%,
        rgba(10, 10, 24, 0.18) 65%,
        rgba(10, 10, 24, 0) 90%
      ),
      linear-gradient(
        180deg,
        transparent 0%,
        transparent 55%,
        rgba(10, 10, 24, 0.55) 88%,
        var(--bg-deep) 100%
      );
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    padding-block: var(--space-10);
    width: 100%;
    /* Break out of the standard 1280px container so the copy can
       sit close to the actual left edge of the viewport. */
    max-width: none;
    padding-inline: clamp(1.5rem, 5vw, 4rem);
  }

  .hero__copy {
    max-width: 500px;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-4);
    animation: fade-up 700ms var(--ease-out) 200ms both;
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
    display: flex;
    flex-direction: column;
    margin-bottom: var(--space-5);
    animation: fade-up 800ms var(--ease-out) 300ms both;
    /* Drop shadow keeps the title crisp over the photo wherever the
       overlay is thinner. */
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
  }
  .hero__title span:first-child {
    color: var(--pink);
  }

  .hero__rule {
    width: 80px;
    height: 2px;
    background: var(--gradient-rule);
    margin-bottom: var(--space-5);
    animation: width-in 900ms var(--ease-out) 400ms both;
  }

  .hero__lede {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-primary);
    margin-bottom: var(--space-6);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
    animation: fade-up 900ms var(--ease-out) 500ms both;
  }

  .hero__more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pink);
    animation: fade-up 1000ms var(--ease-out) 600ms both;
    transition: gap var(--duration-fast) var(--ease-out);
  }
  .hero__more:hover { gap: var(--space-3); }

  /* ══════════════════════════════════════════════════════════
     PRODUCT GRID
     ══════════════════════════════════════════════════════════ */
  .products {
    padding-block: var(--space-10) var(--space-8);
  }

  .products__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  /* ══════════════════════════════════════════════════════════
     IRIS CARD — bulletproof aspect-ratio via padding-top trick.
     The image is absolutely positioned inside an overflow-hidden
     box, so it physically cannot blow out the card layout.
     ══════════════════════════════════════════════════════════ */
  .iris-card {
    --accent: var(--blue);
    --accent-soft: rgba(123, 197, 255, 0.18);

    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-card-2) 100%);
    border-radius: 18px;
    box-shadow: var(--glow-card);
    transition:
      transform var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out);
  }
  .iris-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--glow-card-hover);
  }

  .iris-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .iris-card__name {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: 2.4rem;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--accent);
  }
  .iris-card__subtitle {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  /* The bulletproof container — padding-top establishes 4:3 ratio.
     NO overflow:hidden and NO background here — overflow:hidden was
     clipping the emblem's drop-shadow at the rectangular boundary,
     which created the visible "box" outline. Letting the shadow
     extend naturally lets the emblem appear to float on the card. */
  .iris-card__media {
    position: relative;
    width: 100%;
    padding-top: 75%;
    margin-block: var(--space-2);
  }

  .iris-card__emblem {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 68%;
    height: auto;
    /* PNG is now genuinely transparent — no blend mode or alpha filter
       needed. Drop-shadow gives the iridescent ring its purple glow. */
    filter: drop-shadow(0 0 28px rgba(157, 123, 255, 0.45));
    animation: iris-glow 7s ease-in-out infinite;
  }
  @keyframes iris-glow {
    0%, 100% { filter: drop-shadow(0 0 22px rgba(157, 123, 255, 0.40)); }
    50%      { filter: drop-shadow(0 0 36px rgba(157, 123, 255, 0.65)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .iris-card__emblem { animation: none; }
  }

  .iris-card__desc {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text-secondary);
  }

  .iris-card__specs {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-block: var(--space-3) var(--space-2);
  }
  .iris-card__specs li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-secondary);
  }
  .iris-card .spec-star {
    color: var(--accent);
    flex-shrink: 0;
  }

  .iris-card__cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    border: 1.5px solid var(--accent);
    border-radius: 10px;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    transition:
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }
  .iris-card__cta:hover {
    background: var(--accent);
    color: var(--bg-deep);
  }
  .iris-card__cta:active { transform: scale(0.98); }

  /* ══════════════════════════════════════════════════════════
     VALUE PROPS — full-bleed band across the bottom of the page.
     Section background goes edge-to-edge; content centered inside
     the standard container max-width.
     ══════════════════════════════════════════════════════════ */
  .value-props {
    margin-top: var(--space-10);
    padding-block: var(--space-8);
    background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-card-2) 100%);
    border-top: 1px solid var(--border-soft);
    border-bottom: 1px solid var(--border-soft);
  }

  .value-props__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  /* ══════════════════════════════════════════════════════════
     ANIMATIONS
     ══════════════════════════════════════════════════════════ */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes width-in {
    from { width: 0; }
    to   { width: 80px; }
  }
  @keyframes hero-bg-in {
    from { opacity: 0; transform: scale(1.04); }
    to   { opacity: 1; transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__bg, .hero__eyebrow, .hero__title, .hero__lede,
    .hero__more, .hero__rule {
      animation: none;
    }
  }

  /* ══════════════════════════════════════════════════════════
     RESPONSIVE
     ══════════════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .products__grid { grid-template-columns: repeat(2, 1fr); }
    .value-props__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 720px) {
    .hero { min-height: clamp(440px, 60vh, 600px); }
    .hero__copy { max-width: 100%; }
    /* On mobile, darken further so text remains readable across the
       whole frame, since there's no room to bias left vs. right. */
    .hero__overlay {
      background:
        linear-gradient(
          180deg,
          rgba(10, 10, 24, 0.78) 0%,
          rgba(10, 10, 24, 0.55) 50%,
          rgba(10, 10, 24, 0.82) 100%
        );
    }
    .products__grid { grid-template-columns: 1fr; }
    .value-props__grid { grid-template-columns: 1fr; }
  }
</style>
